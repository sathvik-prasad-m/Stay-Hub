<% layout("/layouts/boilerplate") %>
<style>
  .form-section { background: #f9f9f9; border-radius: 1rem; padding: 1.5rem; margin-bottom: 1.5rem; }
  .form-section-title { font-weight: 700; font-size: 1.1rem; color: #222; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; }
  .form-section-title i { color: #fe424d; }
  .form-hint { font-size: 0.78rem; color: #717171; margin-top: 0.2rem; }
  .optional-badge { font-size: 0.7rem; color: #717171; font-weight: 400; margin-left: 0.5rem; }
</style>
<body>
  <div class="row">
    <div class="col-8 offset-2">
      <h3 class="mb-3">Edit Listing</h3>
      <form action="/listings/<%= listing._id %>?_method=PUT" method="POST" novalidate class="needs-validation" enctype="multipart/form-data">

        <!-- Basic Info -->
        <div class="form-section">
          <div class="form-section-title"><i class="fa-solid fa-circle-info"></i> Basic Information</div>
          <div class="mb-3">
            <label class="form-label">Title</label>
            <input type="text" name="listing[title]" value="<%= listing.title %>" class="form-control" required />
          </div>
          <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea name="listing[description]" class="form-control" rows="3" required><%= listing.description %></textarea>
          </div>
          <div class="mb-3">
            Original Image<br />
            <img src="<%= originalImageUrl %>" alt="" style="border-radius:0.5rem; margin-top:0.5rem;" />
          </div>
          <div class="mb-3">
            <label class="form-label">Upload New Image</label>
            <input type="file" name="listing[image]" class="form-control" />
          </div>
          <div class="row">
            <div class="mb-3 col-md-4">
              <label class="form-label">Price per night (₹)</label>
              <input type="number" name="listing[price]" value="<%= listing.price %>" class="form-control" min="0" required />
            </div>
            <div class="mb-3 col-md-4">
              <label class="form-label">Location</label>
              <input type="text" name="listing[location]" value="<%= listing.location %>" class="form-control" required />
            </div>
            <div class="mb-3 col-md-4">
              <label class="form-label">Country</label>
              <input type="text" name="listing[country]" value="<%= listing.country %>" class="form-control" required />
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Category</label>
            <select name="listing[category]" class="form-select">
              <option value="">Select a category</option>
              <% const categories = ["Rooms","Iconic Cities","Mountains","Castles","Amazing Pools","Camping","Farms","Arctic","Domes","Boats","Beachfront","Lakeside","Treehouses","Luxury","Countryside","Desert","Tropical","Ski-in/out","Vineyards","Historical"]; %>
              <% for (let cat of categories) { %>
              <option value="<%= cat %>" <%= listing.category === cat ? 'selected' : '' %>><%= cat %></option>
              <% } %>
            </select>
          </div>
        </div>

        <!-- Room & Capacity -->
        <div class="form-section">
          <div class="form-section-title"><i class="fa-solid fa-bed"></i> Room & Capacity <span class="optional-badge">Optional</span></div>
          <div class="row">
            <div class="mb-3 col-md-4">
              <label class="form-label">Total Rooms</label>
              <input type="number" name="listing[totalRooms]" class="form-control" value="<%= listing.totalRooms != null ? listing.totalRooms : '' %>" placeholder="e.g. 5" min="1" />
            </div>
            <div class="mb-3 col-md-4">
              <label class="form-label">Max Guests per Room</label>
              <input type="number" name="listing[maxGuestsPerRoom]" class="form-control" value="<%= listing.maxGuestsPerRoom != null ? listing.maxGuestsPerRoom : '' %>" placeholder="e.g. 2" min="1" />
            </div>
            <div class="mb-3 col-md-4">
              <label class="form-label">Bed Type</label>
              <select name="listing[bedType]" class="form-select">
                <option value="">Not specified</option>
                <% const beds = ["Single","Double","Queen","King"]; %>
                <% for (let b of beds) { %>
                <option value="<%= b %>" <%= listing.bedType === b ? 'selected' : '' %>><%= b %></option>
                <% } %>
              </select>
            </div>
          </div>
        </div>

        <!-- Availability -->
        <div class="form-section">
          <div class="form-section-title"><i class="fa-solid fa-calendar-days"></i> Availability <span class="optional-badge">Optional</span></div>
          <div class="row">
            <div class="mb-3 col-12">
              <label class="form-label">Availability Window</label>
              <div class="date-picker-trigger" id="availDatePicker" style="width:100%;">
                <i class="fa-solid fa-calendar-days"></i>
                <span class="<%= listing.availableFrom && listing.availableTo ? 'dp-label' : 'dp-placeholder' %>"><%= listing.availableFrom && listing.availableTo ? '' : 'Select availability range' %></span>
              </div>
              <input type="hidden" name="listing[availableFrom]" id="availFromInput" value="<%= listing.availableFrom ? new Date(listing.availableFrom).toISOString().split('T')[0] : '' %>" />
              <input type="hidden" name="listing[availableTo]" id="availToInput" value="<%= listing.availableTo ? new Date(listing.availableTo).toISOString().split('T')[0] : '' %>" />
            </div>
          </div>
          <div class="row">
            <div class="mb-3 col-md-6">
              <label class="form-label">Minimum Stay (nights)</label>
              <input type="number" name="listing[minStay]" class="form-control" value="<%= listing.minStay != null ? listing.minStay : '' %>" placeholder="e.g. 2" min="1" />
            </div>
            <div class="mb-3 col-md-6">
              <label class="form-label">Maximum Stay (nights)</label>
              <input type="number" name="listing[maxStay]" class="form-control" value="<%= listing.maxStay != null ? listing.maxStay : '' %>" placeholder="e.g. 30" min="1" />
            </div>
          </div>
        </div>

        <!-- Pricing -->
        <div class="form-section">
          <div class="form-section-title"><i class="fa-solid fa-indian-rupee-sign"></i> Advanced Pricing <span class="optional-badge">Optional</span></div>
          <div class="row">
            <div class="mb-3 col-md-4">
              <label class="form-label">Weekend Price / night</label>
              <input type="number" name="listing[weekendPrice]" class="form-control" value="<%= listing.weekendPrice != null ? listing.weekendPrice : '' %>" placeholder="Same as base" min="0" />
            </div>
            <div class="mb-3 col-md-4">
              <label class="form-label">Extra Guest Charge / night</label>
              <input type="number" name="listing[extraGuestCharge]" class="form-control" value="<%= listing.extraGuestCharge != null ? listing.extraGuestCharge : '' %>" placeholder="0" min="0" />
            </div>
            <div class="mb-3 col-md-4">
              <label class="form-label">Cleaning Fee</label>
              <input type="number" name="listing[cleaningFee]" class="form-control" value="<%= listing.cleaningFee != null ? listing.cleaningFee : '' %>" placeholder="0" min="0" />
            </div>
          </div>
          <div class="row">
            <div class="mb-3 col-md-6">
              <label class="form-label">Weekly Discount (%)</label>
              <input type="number" name="listing[weeklyDiscount]" class="form-control" value="<%= listing.weeklyDiscount != null ? listing.weeklyDiscount : '' %>" placeholder="0" min="0" max="100" />
            </div>
            <div class="mb-3 col-md-6">
              <label class="form-label">Monthly Discount (%)</label>
              <input type="number" name="listing[monthlyDiscount]" class="form-control" value="<%= listing.monthlyDiscount != null ? listing.monthlyDiscount : '' %>" placeholder="0" min="0" max="100" />
            </div>
          </div>
        </div>

        <!-- House Rules -->
        <div class="form-section">
          <div class="form-section-title"><i class="fa-solid fa-scroll"></i> House Rules <span class="optional-badge">Optional</span></div>
          <div class="row">
            <div class="mb-3 col-md-6">
              <label class="form-label">Check-in Time</label>
              <input type="time" name="listing[checkInTime]" class="form-control" value="<%= listing.checkInTime || '' %>" />
            </div>
            <div class="mb-3 col-md-6">
              <label class="form-label">Check-out Time</label>
              <input type="time" name="listing[checkOutTime]" class="form-control" value="<%= listing.checkOutTime || '' %>" />
            </div>
          </div>
          <div class="d-flex gap-4 mb-3 flex-wrap">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="listing[petsAllowed]" id="petsAllowed" <%= listing.petsAllowed ? 'checked' : '' %> />
              <label class="form-check-label" for="petsAllowed"><i class="fa-solid fa-paw me-1"></i> Pets allowed</label>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="listing[smokingAllowed]" id="smokingAllowed" <%= listing.smokingAllowed ? 'checked' : '' %> />
              <label class="form-check-label" for="smokingAllowed"><i class="fa-solid fa-smoking me-1"></i> Smoking allowed</label>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="listing[partiesAllowed]" id="partiesAllowed" <%= listing.partiesAllowed ? 'checked' : '' %> />
              <label class="form-check-label" for="partiesAllowed"><i class="fa-solid fa-champagne-glasses me-1"></i> Parties allowed</label>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Custom Rules</label>
            <textarea name="listing[customRules]" class="form-control" rows="2"><%= listing.customRules || '' %></textarea>
          </div>
        </div>

        <!-- Cancellation Policy -->
        <div class="form-section">
          <div class="form-section-title"><i class="fa-solid fa-shield-halved"></i> Cancellation Policy <span class="optional-badge">Optional</span></div>
          <div class="mb-3">
            <select name="listing[cancellationPolicy]" class="form-select">
              <option value="">Not specified</option>
              <option value="flexible" <%= listing.cancellationPolicy === 'flexible' ? 'selected' : '' %>>Flexible — Full refund up to 1 day before check-in</option>
              <option value="moderate" <%= listing.cancellationPolicy === 'moderate' ? 'selected' : '' %>>Moderate — Full refund up to 5 days before check-in</option>
              <option value="strict" <%= listing.cancellationPolicy === 'strict' ? 'selected' : '' %>>Strict — 50% refund up to 7 days before check-in</option>
            </select>
          </div>
        </div>

        <button class="btn btn-dark edit-btn mt-2 mb-4">Update Listing</button>
      </form>
    </div>
  </div>
</body>
<script src="/js/datepicker.js"></script>
<script>
  const availTrigger = document.getElementById("availDatePicker");
  if (availTrigger) {
    new StayHubDatePicker({
      trigger: availTrigger,
      fromInput: document.getElementById("availFromInput"),
      toInput: document.getElementById("availToInput"),
    });
  }
</script>
